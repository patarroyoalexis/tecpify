NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# opcional: usa 1/true para exponer Google OAuth solo como opcion secundaria en /login
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=0
# opcional en runtime normal; requerida solo para bootstrap test-only de Playwright desde lib/supabase/internal/service-role-client.ts
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# tests E2E con Playwright
PLAYWRIGHT_BASE_URL=http://localhost:3000
# obligatoria: secreto unico para bootstrapear fixtures E2E dedicadas y no humanas sin disparar correos
PLAYWRIGHT_E2E_PASSWORD=
# opcional: namespace para aislar fixtures cuando varios entornos comparten el mismo proyecto de Supabase
PLAYWRIGHT_E2E_NAMESPACE=
# opcional: usa 1 para correr contra un servidor ya levantado manualmente
PLAYWRIGHT_SKIP_WEBSERVER=
# opcional: lo usan runners automatizados para activar retries/reportes de CI
CI=
